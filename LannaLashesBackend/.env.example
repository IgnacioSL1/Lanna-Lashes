# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lanna_lashes"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN="lannalashes.myshopify.com"
SHOPIFY_STOREFRONT_TOKEN="your_storefront_access_token"
SHOPIFY_ADMIN_TOKEN="your_admin_api_token"

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN="your_private_app_token"
# HubSpot timeline event template IDs (create these in HubSpot)
HUBSPOT_EVENT_COURSE_PURCHASED="your_event_template_id"
HUBSPOT_EVENT_COURSE_COMPLETED="your_event_template_id"

# ── AWS S3 (community image uploads) ─────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_key"
AWS_SECRET_ACCESS_KEY="your_secret"
AWS_S3_BUCKET="lanna-lashes-uploads"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
